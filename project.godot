; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Kingdom Fall"
run/main_scene="uid://bw1l202axfrki"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="uid://cj1m8aroronnd"

[autoload]

ee="*res://src/Autoloads/EffectEngine.gd"
Bus="*res://src/Autoloads/SignalBus.gd"
kf="*res://src/Autoloads/KingdomFall.gd"
Utils="*res://src/Autoloads/Utils.gd"
R="*res://src/Autoloads/Resources.gd"
Settings="*res://src/Autoloads/UserSettings.gd"
Audio="*res://src/Autoloads/Audio.gd"

[debug]

gdscript/warnings/unused_signal=0

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"
mouse_cursor/custom_image="uid://cbfuu0tudcjm5"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_resource_groups/plugin.cfg")

[godot_resource_groups]

auto_rebuild=true
